# Подключение к PostgreSQL (база fitness_db)
# НЕ подставляйте admin/admin123 — это только для входа на сайте!
#
# Mac (Homebrew), без пароля — часто достаточно имени пользователя macOS:
# DATABASE_URL=postgresql://elizaveta@localhost:5432/fitness_db
#
# С паролем:
# DATABASE_URL=postgresql://postgres:ваш_пароль@localhost:5432/fitness_db

# DATABASE_URL=postgresql://ИМЯ_ПОЛЬЗОВАТЕЛЯ_PG@localhost:5432/fitness_db

# External URL с Render — для populate_db.py с Mac (без Shell):
# DATABASE_URL=postgresql://user:pass@host.oregon-postgres.render.com/dbname?sslmode=require

# Одноразовая кнопка «Демо-данные» в админке (потом удалить!):
# ALLOW_DEMO_SEED=1
